# Environment variables for SymbioteSystems CEO Agent

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3 # or mistral

# n8n Configuration
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your_n8n_api_key

# ChromaDB Configuration (for agent memory persistence)
CHROMADB_PATH=./chroma_db

# Social Media API Keys (placeholders - actual implementation will use n8n)
# FACEBOOK_API_KEY=your_facebook_api_key
# INSTAGRAM_API_KEY=your_instagram_api_key
# TWITTER_API_KEY=your_twitter_api_key
# TIKTOK_API_KEY=your_tiktok_api_key
# PINTEREST_API_KEY=your_pinterest_api_key
# YOUTUBE_API_KEY=your_youtube_api_key

# Brand Guidelines (example - these might be loaded from a config file or directly used by agents)
BRAND_NAME="SymbioteSystems"
BRAND_NICHE="AI, automation, digital products, cybersecurity"
BRAND_AESTHETIC="Dark, high-contrast, geometric, classified/executive style"
BRAND_AUDIENCE="HNWIs, executives, entrepreneurs, digital marketers"

# Other configurations
DAILY_REPORT_RECIPIENT_EMAIL=your_email@example.com
