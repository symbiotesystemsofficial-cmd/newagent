        "subject": "{{ $('Webhook').data.body.subject }}",
        "text": "{{ $('Webhook').data.body.body }}"
      },
      "name": "Send Email",
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 1,
      "id": "d4e5f6g7-8h9i-0j1k-2l3m-4n5o6p7q8r9s",
      "credentials": {
        "emailSmtp": {
          "id": "your-smtp-credential-id",
          "name": "SMTP Account"
        }
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          { "node": "Send Email", "type": "main" }
        ]
      ]
    }
  }
